# ============================================================================
# ORION ARCHITEKT AT - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------
APP_NAME=ORION Architekt AT
APP_VERSION=1.0.0

# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode (NEVER use true in production!)
DEBUG=false

# ----------------------------------------------------------------------------
# SECURITY (REQUIRED)
# ----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-min-32-chars-CHANGE-THIS

# JWT Authentication
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-CHANGE-THIS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Session Secret
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-CHANGE-THIS

# ----------------------------------------------------------------------------
# DATABASE (REQUIRED)
# ----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Generate password with: openssl rand -base64 24
DATABASE_URL=postgresql://orion:YOUR_SECURE_PASSWORD@localhost:5432/orion_db

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ----------------------------------------------------------------------------
# REDIS (OPTIONAL - for caching and rate limiting)
# ----------------------------------------------------------------------------
# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Redis connection pool
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5

# ----------------------------------------------------------------------------
# EXTERNAL APIS
# ----------------------------------------------------------------------------
# RIS Austria (Rechtsinformationssystem) - Legal database
# Get API key from: https://www.ris.bka.gv.at/
RIS_API_KEY=

# hora.gv.at - Natural hazards mapping
# Get API key from: https://www.hora.gv.at/
HORA_API_KEY=

# Austrian Building Price Index (Baupreisindex)
# Get API key from: https://www.statistik.at/
STATISTIK_AUSTRIA_API_KEY=

# OpenAI API (for AI-powered quantity takeoff)
# Get API key from: https://platform.openai.com/
OPENAI_API_KEY=

# Google Geocoding API (for address validation)
# Get API key from: https://console.cloud.google.com/
GOOGLE_GEOCODING_API_KEY=

# ----------------------------------------------------------------------------
# FILE UPLOAD SETTINGS
# ----------------------------------------------------------------------------
# Maximum upload size in megabytes
MAX_UPLOAD_SIZE_MB=100

# Allowed file extensions (comma-separated)
# IFC files: .ifc, .ifcxml
# CAD files: .dwg, .dxf
# Documents: .pdf
# Images: .png, .jpg, .jpeg
ALLOWED_EXTENSIONS=.ifc,.ifcxml,.dwg,.dxf,.pdf,.png,.jpg,.jpeg

# Upload directory (absolute path)
UPLOAD_DIR=/var/lib/orion/uploads

# Temporary files directory
TEMP_DIR=/tmp/orion

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (production) or text (development)
LOG_FORMAT=text

# Log file path (optional - logs to stdout if not set)
LOG_FILE=

# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io/
SENTRY_DSN=

# ----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ----------------------------------------------------------------------------
# Allowed origins (JSON array format)
# Development example: ["http://localhost:3000","http://localhost:8080"]
# Production example: ["https://orion.example.com","https://app.example.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true

# Allowed methods
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS","PATCH"]

# Allowed headers
CORS_ALLOW_HEADERS=["*"]

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
# Requests per minute per IP address
RATE_LIMIT_PER_MINUTE=60

# Rate limit for authenticated users
RATE_LIMIT_AUTHENTICATED_PER_MINUTE=300

# Rate limit for file uploads
RATE_LIMIT_UPLOAD_PER_HOUR=20

# ----------------------------------------------------------------------------
# EMAIL (OPTIONAL - for notifications)
# ----------------------------------------------------------------------------
# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=

# Email sender
EMAIL_FROM=noreply@orion-architekt.at
EMAIL_FROM_NAME=ORION Architekt AT

# Admin email for system notifications
ADMIN_EMAIL=

# ----------------------------------------------------------------------------
# ANALYTICS (OPTIONAL)
# ----------------------------------------------------------------------------
# Google Analytics Measurement ID
# Format: G-XXXXXXXXXX
# Get from: https://analytics.google.com/
GOOGLE_ANALYTICS_ID=

# Matomo/Piwik Analytics (alternative to Google Analytics)
MATOMO_URL=
MATOMO_SITE_ID=

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
# Enable AI-powered quantity takeoff
FEATURE_AI_TAKEOFF=true

# Enable real-time collaboration
FEATURE_COLLABORATION=true

# Enable e-procurement integration
FEATURE_E_PROCUREMENT=true

# Enable eIDAS digital signatures
FEATURE_EIDAS_SIGNATURES=false

# Enable BIM/IFC processing
FEATURE_BIM_PROCESSING=true

# ----------------------------------------------------------------------------
# AUSTRIAN BUILDING STANDARDS
# ----------------------------------------------------------------------------
# Default Bundesland (if not specified in request)
# Options: wien, niederoesterreich, oberoesterreich, steiermark,
#          kaernten, salzburg, tirol, vorarlberg, burgenland
DEFAULT_BUNDESLAND=wien

# OIB-RL version to use
# Options: 2019, 2023
OIB_RL_VERSION=2019

# ÖNORM standards database update frequency (days)
OENORM_UPDATE_FREQUENCY_DAYS=30

# ----------------------------------------------------------------------------
# PERFORMANCE & CACHING
# ----------------------------------------------------------------------------
# Enable response caching
ENABLE_CACHING=true

# Cache TTL in seconds
CACHE_TTL_DEFAULT=3600
CACHE_TTL_STANDARDS=86400
CACHE_TTL_CALCULATIONS=7200

# Enable query optimization
ENABLE_QUERY_OPTIMIZATION=true

# ----------------------------------------------------------------------------
# MONITORING & HEALTH CHECKS
# ----------------------------------------------------------------------------
# Enable Prometheus metrics endpoint
ENABLE_METRICS=true

# Enable health check endpoint
ENABLE_HEALTH_CHECK=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=60

# ----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS (DO NOT USE IN PRODUCTION!)
# ----------------------------------------------------------------------------
# Enable API documentation
ENABLE_DOCS=true

# Enable ReDoc documentation
ENABLE_REDOC=true

# Enable Swagger UI
ENABLE_SWAGGER_UI=true

# Auto-reload on code changes
AUTO_RELOAD=true

# ----------------------------------------------------------------------------
# BACKUP & DISASTER RECOVERY
# ----------------------------------------------------------------------------
# Backup directory
BACKUP_DIR=/var/backups/orion

# Backup frequency (cron expression)
# Default: daily at 2 AM
BACKUP_SCHEDULE=0 2 * * *

# Number of backups to retain
BACKUP_RETENTION_DAYS=30

# ----------------------------------------------------------------------------
# COMPLIANCE & AUDIT
# ----------------------------------------------------------------------------
# Enable audit logging
ENABLE_AUDIT_LOG=true

# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=365

# Enable GDPR compliance features
ENABLE_GDPR_COMPLIANCE=true

# Data retention period (days)
DATA_RETENTION_DAYS=2555  # 7 years (Austrian legal requirement)

# ----------------------------------------------------------------------------
# INTERNATIONALIZATION
# ----------------------------------------------------------------------------
# Default language
# Options: de (German), en (English)
DEFAULT_LANGUAGE=de

# Available languages (comma-separated)
AVAILABLE_LANGUAGES=de,en

# Timezone
TIMEZONE=Europe/Vienna

# ----------------------------------------------------------------------------
# TESTING (ONLY USE IN TEST ENVIRONMENT!)
# ----------------------------------------------------------------------------
# Use in-memory database for testing
TEST_DATABASE_URL=sqlite:///:memory:

# Disable authentication in tests
TEST_DISABLE_AUTH=false

# Mock external API calls in tests
TEST_MOCK_EXTERNAL_APIS=true

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Generate secrets:
#    SECRET_KEY=$(openssl rand -hex 32)
#    JWT_SECRET_KEY=$(openssl rand -hex 64)
#    SESSION_SECRET=$(openssl rand -base64 32)
# 3. Set database password:
#    DB_PASSWORD=$(openssl rand -base64 24)
# 4. Update DATABASE_URL with your password
# 5. Configure external API keys (optional)
# 6. Review and adjust all settings for your environment
# 7. NEVER commit .env to version control!
# ============================================================================
