import json
import sys
import os
from unittest.mock import AsyncMock, MagicMock, patch

import pytest
from fastapi.testclient import TestClient

# Add parent directory to path
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

# Import app
from api.main import app

# Create test client
client = TestClient(app)


# ============================================================================
# FIXTURES
# ============================================================================


@pytest.fixture
def mock_psutil():
    """Mock psutil for system metrics"""
    with patch("api.routers.monitoring.psutil") as mock:
        mock.cpu_percent.return_value = 45.5
        mock.virtual_memory.return_value = MagicMock(
            percent=60.2, available=1024 * 1024 * 1024 * 4
        )
        mock.disk_usage.return_value = MagicMock(
            percent=50.0, free=1024 * 1024 * 1024 * 100
        )
        yield mock


@pytest.fixture
def mock_redis():
    """Mock Redis client"""
    with patch("api.routers.monitoring.redis_client") as mock:
        mock.ping.return_value = True
        mock.info.return_value = {
            "redis_version": "7.0.0",
            "uptime_in_seconds": 86400 * 10,
        }
        yield mock


# ============================================================================
# HEALTH CHECK TESTS
# ============================================================================


class TestHealthCheck:
    """Test comprehensive health check endpoint"""

    def test_health_check_success(self, mock_psutil, mock_redis):
        """Test successful health check"""
        response = client.get("/health")

        assert response.status_code == 200
        data = response.json()

        assert "status" in data
        assert "timestamp" in data
        assert "version" in data
        assert "checks" in data
        assert "system" in data

    def test_health_check_response_format(self, mock_psutil, mock_redis):
        """Test health check response format"""
        response = client.get("/health")
        data = response.json()

        # Check top-level structure
        assert data["status"] in ["healthy", "degraded", "unhealthy"]
        assert isinstance(data["timestamp"], str)
        assert isinstance(data["version"], str)

        # Check checks structure
        assert "database" in data["checks"]
        assert "redis" in data["checks"]
        assert "ifcopenshell" in data["checks"]

        for check_name, check_data in data["checks"].items():
            assert "status" in check_data
            assert check_data["status"] in [
                "healthy",
                "unhealthy",
                "degraded",
                "disabled",
                "unknown",
                "unavailable",
            ]

        # Check system metrics
        assert "cpu_percent" in data["system"]
        assert "memory_percent" in data["system"]
        assert "memory_available_gb" in data["system"]
        assert "disk_percent" in data["system"]
        assert "disk_free_gb" in data["system"]

    def test_health_check_database_check(self, mock_psutil):
        """Test database check component"""
        response = client.get("/health")
        data = response.json()

        db_check = data["checks"]["database"]
        assert "status" in db_check
        # Status could be healthy, unhealthy, or unknown depending on DB availability

    def test_health_check_redis_check(self, mock_psutil, mock_redis):
        """Test Redis check component"""
        response = client.get("/health")
        data = response.json()

        redis_check = data["checks"]["redis"]
        assert "status" in redis_check

    def test_health_check_ifcopenshell_check(self, mock_psutil):
        """Test ifcopenshell check component"""
        response = client.get("/health")
        data = response.json()

        ifc_check = data["checks"]["ifcopenshell"]
        assert "status" in ifc_check
        # Status will be 'healthy' if ifcopenshell is installed, else 'unavailable'

    def test_health_check_system_metrics(self, mock_psutil):
        """Test system metrics in health check"""
        response = client.get("/health")
        data = response.json()

        system = data["system"]
        assert system["cpu_percent"] == 45.5
        assert system["memory_percent"] == 60.2
        assert system["memory_available_gb"] > 0
        assert system["disk_percent"] == 50.0
        assert system["disk_free_gb"] > 0

    def test_health_check_unhealthy_database(self, mock_psutil, mock_redis):
        """Test health check when database is unhealthy"""
        # This would require mocking the database to fail
        # In normal conditions, this test checks the response structure
        response = client.get("/health")
        data = response.json()

        # Status should be 200 or 503 depending on database health
        assert response.status_code in [200, 503]

    @patch("api.routers.monitoring.psutil.cpu_percent")
    def test_health_check_system_metrics_error(self, mock_cpu, mock_psutil, mock_redis):
        """Test health check when system metrics fail"""
        mock_cpu.side_effect = Exception("CPU check failed")

        response = client.get("/health")
        data = response.json()

        # Should still return health check even if metrics fail
        assert response.status_code in [200, 503]


# ============================================================================
# READINESS PROBE TESTS
# ============================================================================


class TestReadinessProbe:
    """Test Kubernetes readiness probe endpoint"""

    def test_readiness_probe_ready(self, mock_psutil, mock_redis):
        """Test readiness probe when ready"""
        response = client.get("/health/ready")

        # Should return 200 if ready, 503 if not ready
        assert response.status_code in [200, 503]

    def test_readiness_probe_response_format(self, mock_psutil, mock_redis):
        """Test readiness probe response format"""
        response = client.get("/health/ready")

        # Should be plain text response
        assert response.status_code in [200, 503]
        assert isinstance(response.text, str)

    def test_readiness_probe_content(self, mock_psutil, mock_redis):
        """Test readiness probe content"""
        response = client.get("/health/ready")

        # Content should be 'ready' or 'not ready'
        assert response.text in ["ready", "not ready"]


# ============================================================================
# LIVENESS PROBE TESTS
# ============================================================================


class TestLivenessProbe:
    """Test Kubernetes liveness probe endpoint"""

    def test_liveness_probe_always_alive(self, mock_psutil, mock_redis):
        """Test liveness probe always returns 200"""
        response = client.get("/health/live")

        assert response.status_code == 200
        assert response.text == "alive"

    def test_liveness_probe_no_external_checks(self, mock_psutil, mock_redis):
        """Test liveness probe doesn't check external dependencies"""
        # Liveness probe should be lightweight and not check databases
        response = client.get("/health/live")

        assert response.status_code == 200
        # Content should be 'alive'
        assert "alive" in response.text.lower()


# ============================================================================
# METRICS ENDPOINT TESTS
# ============================================================================


class TestMetricsEndpoint:
    """Test Prometheus metrics endpoint"""

    def test_metrics_endpoint_available(self, mock_psutil):
        """Test metrics endpoint is available"""
        response = client.get("/metrics")

        # Should return 200 if Prometheus available, 503 otherwise
        assert response.status_code in [200, 503]

    def test_metrics_endpoint_format(self, mock_psutil):
        """Test metrics endpoint returns proper format"""
        response = client.get("/metrics")

        if response.status_code == 200:
            # Should be Prometheus text format
            assert "text/plain" in response.headers.get("content-type", "")
            # Prometheus metrics should contain HELP and TYPE lines
            content = response.text
            # Content should be plain text (Prometheus format)
            assert isinstance(content, str)

    def test_metrics_endpoint_error_message(self, mock_psutil):
        """Test metrics endpoint error message"""
        response = client.get("/metrics")

        if response.status_code == 503:
            # Should contain error message
            data = response.json()
            assert "error" in data or "details" in data


