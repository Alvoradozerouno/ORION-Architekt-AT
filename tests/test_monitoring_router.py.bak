class TestDetailedDiagnostics:
    """Test detailed diagnostic endpoint"""

    def test_detailed_diagnostics_success(self, mock_psutil, mock_redis):
        """Test detailed diagnostics endpoint"""
        response = client.get("/health/detailed")

        assert response.status_code == 200
        data = response.json()

        assert "timestamp" in data
        assert "python" in data
        assert "system" in data
        assert "health_checks" in data

    def test_diagnostics_python_info(self, mock_psutil, mock_redis):
        """Test Python version info in diagnostics"""
        response = client.get("/health/detailed")
        data = response.json()

        python_info = data["python"]
        assert "version" in python_info
        assert "executable" in python_info
        assert "platform" in python_info

    def test_diagnostics_system_info(self, mock_psutil, mock_redis):
        """Test system info in diagnostics"""
        response = client.get("/health/detailed")
        data = response.json()

        system_info = data["system"]
        assert "cpu_percent" in system_info
        assert "memory_percent" in system_info

    def test_diagnostics_health_checks(self, mock_psutil, mock_redis):
        """Test health checks in diagnostics"""
        response = client.get("/health/detailed")
        data = response.json()

        health_checks = data["health_checks"]
        assert "database" in health_checks
        assert "redis" in health_checks
        assert "ifcopenshell" in health_checks

    def test_diagnostics_package_versions(self, mock_psutil, mock_redis):
        """Test package versions in diagnostics"""
        response = client.get("/health/detailed")
        data = response.json()

        # Packages should be present or have error message
        if "packages" in data:
            assert isinstance(data["packages"], dict)


# ============================================================================
# INTEGRATION TESTS
# ============================================================================


class TestMonitoringIntegration:
    """Integration tests for monitoring endpoints"""

    def test_all_endpoints_accessible(self, mock_psutil, mock_redis):
        """Test all monitoring endpoints are accessible"""
        endpoints = ["/health", "/health/ready", "/health/live", "/metrics", "/health/detailed"]

        for endpoint in endpoints:
            response = client.get(endpoint)
            assert response.status_code in [200, 503], f"Endpoint {endpoint} failed"

    def test_health_consistency(self, mock_psutil, mock_redis):
        """Test health check consistency across calls"""
        response1 = client.get("/health")
        response2 = client.get("/health")

        assert response1.status_code == response2.status_code

    def test_readiness_consistency(self, mock_psutil, mock_redis):
        """Test readiness probe consistency"""
        response1 = client.get("/health/ready")
        response2 = client.get("/health/ready")

        assert response1.status_code == response2.status_code

    def test_liveness_always_succeeds(self, mock_psutil, mock_redis):
        """Test liveness probe always succeeds"""
        for _ in range(5):
            response = client.get("/health/live")
            assert response.status_code == 200


