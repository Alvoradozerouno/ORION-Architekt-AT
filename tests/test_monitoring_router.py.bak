class TestErrorHandling:
    """Test error handling in monitoring endpoints"""

    def test_health_check_with_invalid_path(self):
        """Test health check with invalid endpoint"""
        response = client.get("/health/invalid")
        assert response.status_code == 404

    def test_metrics_content_type(self, mock_psutil):
        """Test metrics endpoint content type"""
        response = client.get("/metrics")

        if response.status_code == 200:
            # Content type should be text/plain for Prometheus metrics
            assert "text/plain" in response.headers.get("content-type", "")


# ============================================================================
# EDGE CASE TESTS
# ============================================================================


class TestEdgeCases:
    """Test edge cases and boundary conditions"""

    @patch("api.routers.monitoring.psutil.virtual_memory")
    def test_health_check_high_memory_usage(self, mock_memory, mock_psutil, mock_redis):
        """Test health check with high memory usage"""
        mock_memory.return_value = MagicMock(
            percent=99.5, available=1024 * 1024  # Very low available memory
        )

        response = client.get("/health")
        assert response.status_code == 200
        data = response.json()
        assert data["system"]["memory_percent"] == 99.5

    @patch("api.routers.monitoring.psutil.disk_usage")
    def test_health_check_high_disk_usage(self, mock_disk, mock_psutil, mock_redis):
        """Test health check with high disk usage"""
        mock_disk.return_value = MagicMock(
            percent=95.0, free=1024 * 1024 * 100  # Low free space
        )

        response = client.get("/health")
        assert response.status_code == 200
        data = response.json()
        assert data["system"]["disk_percent"] == 95.0

    @patch("api.routers.monitoring.psutil.cpu_percent")
    def test_health_check_high_cpu_usage(self, mock_cpu, mock_psutil, mock_redis):
        """Test health check with high CPU usage"""
        mock_cpu.return_value = 99.9

        response = client.get("/health")
        assert response.status_code == 200
        data = response.json()
        assert data["system"]["cpu_percent"] == 99.9


if __name__ == "__main__":
    pytest.main([__file__, "-v"])
